        <mxCell id="lesson-heading" value="What are Arrow Functions?" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontStyle=1;spacingLeft=20;spacingTop=15" vertex="1" parent="1">
          <mxGeometry x="1090" y="860" width="740" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="lesson-text" value="Arrow functions are a concise way to write function expressions in JavaScript. They were introduced in ES6 and provide a shorter syntax compared to traditional function expressions.&#xa;&#xa;Key Features:&#xa;• Shorter syntax&#xa;• Lexical 'this' binding&#xa;• Cannot be used as constructors&#xa;• No 'arguments' object" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=13;spacingLeft=20;spacingTop=5;whiteSpace=wrap" vertex="1" parent="1">
          <mxGeometry x="1090" y="910" width="740" height="150" as="geometry" />
        </mxCell>
        
        <!-- Code Example -->
        <mxCell id="code-example-title" value="Example:" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=14;fontStyle=1;spacingLeft=20" vertex="1" parent="1">
          <mxGeometry x="1090" y="1070" width="740" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="code-block" value="// Traditional function&#xa;function add(a, b) {&#xa;  return a + b;&#xa;}&#xa;&#xa;// Arrow function&#xa;const add = (a, b) => a + b;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#a855f7;fontSize=12;fontColor=#e5e7eb;align=left;spacingLeft=15;spacingTop=10;fontFamily=Courier New" vertex="1" parent="1">
