PORT=5012

# DynamoDB Configuration
DYNAMODB_USERS_TABLE=hackveda-users
AWS_REGION=ap-south-1

# Tutor Agent
TUTOR_AGENT_ID=your-tutor-agent-id
TUTOR_AGENT_ALIAS=your-tutor-agent-alias

# Curriculum Agent
CURRICULUM_AGENT_ID=your-curriculum-agent-id
CURRICULUM_AGENT_ALIAS=your-curriculum-agent-alias

# Evaluation Agent
EVALUATION_AGENT_ID=your-evaluation-agent-id
EVALUATION_AGENT_ALIAS=your-evaluation-agent-alias

# Skill Mapping Agent
SKILL_MAPPING_AGENT_ID=your-skill-mapping-agent-id
SKILL_MAPPING_AGENT_ALIAS=your-skill-mapping-agent-alias

# Coding Agent
CODING_AGENT_ID=your-coding-agent-id
CODING_AGENT_ALIAS=your-coding-agent-alias

# Test Case Generator Agent
TEST_CASE_GENERATOR_AGENT_ID=your-test-case-agent-id
TEST_CASE_GENERATOR_AGENT_ALIAS=your-test-case-agent-alias

# Chatbot Agent
CHATBOT_AGENT_ID=your-chatbot-agent-id
CHATBOT_AGENT_ALIAS=your-chatbot-agent-alias

# Learning Assistant Agent
LEARNING_ASSISTANT_AGENT_ID=your-learning-assistant-agent-id
LEARNING_ASSISTANT_AGENT_ALIAS=your-learning-assistant-agent-alias

# JWT Secret
JWT_SECRET=your-jwt-secret-key

# Judge0 Configuration
JUDGE0_URL=http://your-judge0-ip:2358

# Note: AWS credentials are automatically loaded from:
# 1. AWS CLI configuration (~/.aws/credentials)
# 2. Environment variables (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
# 3. IAM role (when deployed on EC2/ECS)
