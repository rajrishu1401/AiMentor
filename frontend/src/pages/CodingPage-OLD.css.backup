/* Theme Variables */
:root[data-theme="dark"] {
  --bg-primary: #0f172a;
  --bg-secondary: #1e293b;
  --bg-tertiary: #334155;
  --text-primary: #f1f5f9;
  --text-secondary: #cbd5e1;
  --text-tertiary: #94a3b8;
  --accent: #60a5fa;
  --accent-hover: #3b82f6;
  --success: #10b981;
  --success-hover: #059669;
  --border: #334155;
  --shadow: rgba(0, 0, 0, 0.3);
}

:root[data-theme="light"] {
  --bg-primary: #ffffff;
  --bg-secondary: #f8f9fa;
  --bg-tertiary: #e9ecef;
  --text-primary: #1a1a1a;
  --text-secondary: #4a5568;
  --text-tertiary: #718096;
  --accent: #3b82f6;
  --accent-hover: #2563eb;
  --success: #10b981;
  --success-hover: #059669;
  --border: #e2e8f0;
  --shadow: rgba(0, 0, 0, 0.1);
}

/* Container */
.coding-page-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg-primary);
  color: var(--text-primary);
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  overflow: hidden;
}

/* Header */
.coding-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem 1.5rem;
  background: var(--bg-secondary);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-weight: 600;
  font-size: 1.1rem;
}

.logo-icon {
  background: var(--accent);
  color: white;
  width: 32px;
  height: 32px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  font-size: 0.9rem;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.chatbot-drawer-toggle {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--bg-tertiary);
  border: 1px solid var(--border);
  color: var(--text-primary);
  padding: 0.5rem 1rem;
  border-radius: 6px;
  cursor: pointer;
  font-size: 0.9rem;
  font-weight: 600;
  transition: all 0.2s;
}

.chatbot-drawer-toggle:hover {
  background: var(--accent);
  color: white;
  transform: translateY(-1px);
}

.chatbot-drawer-toggle.active {
  background: var(--accent);
  color: white;
}

.chatbot-drawer-toggle span:first-child {
  font-size: 1.2rem;
}

.theme-toggle {
  background: var(--bg-tertiary);
  border: 1px solid var(--border);
  color: var(--text-primary);
  padding: 0.5rem 0.75rem;
  border-radius: 6px;
  cursor: pointer;
  font-size: 1.2rem;
  transition: all 0.2s;
}

.theme-toggle:hover {
  background: var(--accent);
  transform: scale(1.05);
}

/* Main Content - LeetCode Layout with Drawer */
.coding-main-content {
  display: grid;
  flex: 1;
  overflow: hidden;
  position: relative;
}

/* Vertical Resize Handle */
.vertical-resize-handle {
  width: 8px;
  background: var(--bg-tertiary);
  cursor: ew-resize;
  display: flex;
  align-items: center;
  justify-content: center;
  border-left: 1px solid var(--border);
  border-right: 1px solid var(--border);
  transition: background 0.2s;
  position: relative;
  z-index: 10;
}

.vertical-resize-handle:hover {
  background: var(--accent);
}

.vertical-resize-handle::before {
  content: '';
  width: 3px;
  height: 40px;
  background: var(--text-tertiary);
  border-radius: 2px;
}

.vertical-resize-handle:hover::before {
  background: white;
}

/* Left Panel - Problem Description */
.left-panel {
  background: var(--bg-secondary);
  border-right: 1px solid var(--border);
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}

.problem-header {
  padding: 1.5rem;
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  background: var(--bg-secondary);
  z-index: 10;
}

.problem-header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.problem-title {
  font-size: 1.5rem;
  font-weight: 700;
  margin: 0;
  color: var(--text-primary);
  flex: 1;
}

.problem-description-scroll {
  padding: 1.5rem;
  overflow-y: auto;
  flex: 1;
}

/* Right Panel - Code + Output + Chat */
.right-panel {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* Middle Panel - Code + Output (when drawer is open) */
.middle-panel {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* Chatbot Drawer - Right Side */
.chatbot-drawer {
  background: var(--bg-secondary);
  border-left: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  animation: slideInRight 0.3s ease;
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(20px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.close-drawer-btn {
  background: transparent;
  border: none;
  color: var(--text-primary);
  cursor: pointer;
  font-size: 1.2rem;
  padding: 0.25rem 0.5rem;
  transition: all 0.2s;
  border-radius: 4px;
}

.close-drawer-btn:hover {
  color: var(--accent);
  background: var(--bg-tertiary);
}

/* Chatbot Header */
.chatbot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.75rem 1rem;
  border-bottom: 1px solid var(--border);
  background: var(--bg-tertiary);
  flex-shrink: 0;
}

.chatbot-title {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-weight: 600;
  font-size: 1rem;
}

.chatbot-messages {
  flex: 1;
  overflow-y: auto;
  padding: 1rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

/* Message Styles */
.message {
  display: flex;
  gap: 0.75rem;
  animation: slideIn 0.3s ease;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.message-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  flex-shrink: 0;
}

.message.user .message-avatar {
  background: var(--accent);
}

.message.bot .message-avatar {
  background: var(--success);
}

.message-content {
  flex: 1;
  background: var(--bg-tertiary);
  padding: 0.75rem 1rem;
  border-radius: 12px;
  line-height: 1.5;
  font-size: 0.9rem;
}

.message.user .message-content {
  background: var(--accent);
  color: white;
}

.code-block {
  margin: 0.5rem 0;
  border-radius: 6px;
  overflow: hidden;
  background: var(--bg-primary);
}

.code-block-header {
  background: var(--bg-tertiary);
  padding: 0.5rem 0.75rem;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  color: var(--text-tertiary);
}

.code-block-content {
  padding: 0.75rem;
  margin: 0;
  font-family: 'JetBrains Mono', 'Courier New', monospace;
  font-size: 0.85rem;
  overflow-x: auto;
}

.chatbot-messages {
  flex: 1;
  overflow-y: auto;
  padding: 1rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.chatbot-input-container {
  padding: 1rem;
  border-top: 1px solid var(--border);
  background: var(--bg-secondary);
  flex-shrink: 0;
}

.chatbot-input-wrapper {
  display: flex;
  gap: 0.5rem;
}

.chatbot-input {
  flex: 1;
  padding: 0.75rem;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: var(--bg-primary);
  color: var(--text-primary);
  font-size: 0.9rem;
  outline: none;
  transition: border-color 0.2s;
}

.chatbot-input:focus {
  border-color: var(--accent);
}

.mic-btn {
  padding: 0.75rem;
  background: var(--bg-tertiary);
  border: 1px solid var(--border);
  border-radius: 8px;
  cursor: pointer;
  font-size: 1.2rem;
  transition: all 0.2s;
}

.mic-btn:hover {
  background: var(--accent);
  transform: scale(1.05);
}

.mic-btn.listening {
  background: #ef4444;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.7;
  }
}

.send-btn {
  padding: 0.75rem 1.25rem;
  background: var(--accent);
  color: white;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-weight: 600;
  font-size: 0.9rem;
  transition: all 0.2s;
}

.send-btn:hover {
  background: var(--accent-hover);
  transform: translateY(-1px);
}

/* Code Section */
.code-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--bg-secondary);
}

/* Problem Section Styles */
.badge {
  padding: 0.25rem 0.75rem;
  border-radius: 12px;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
}

.badge-medium {
  background: #f59e0b;
  color: white;
}

.problem-section {
  margin-bottom: 1.5rem;
}

.problem-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--text-primary);
  margin: 0 0 0.75rem 0;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid var(--accent);
  display: inline-block;
}

.section-content {
  font-size: 0.9rem;
  line-height: 1.6;
  color: var(--text-secondary);
}

.section-content p {
  margin: 0;
}

.format-text {
  font-family: 'JetBrains Mono', 'Courier New', monospace;
  font-size: 0.85rem;
  line-height: 1.6;
  margin: 0;
  white-space: pre-wrap;
  color: var(--text-secondary);
  background: var(--bg-secondary);
  padding: 0.75rem;
  border-radius: 6px;
  border: 1px solid var(--border);
}

/* Sample Test Cases */
.sample-case {
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1rem;
  margin-bottom: 1rem;
}

.sample-case:last-child {
  margin-bottom: 0;
}

.sample-header {
  font-weight: 700;
  font-size: 0.9rem;
  color: var(--accent);
  margin-bottom: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.sample-io {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-bottom: 0.75rem;
}

.sample-input,
.sample-output {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.io-label {
  font-weight: 600;
  font-size: 0.85rem;
  color: var(--text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.io-content {
  font-family: 'JetBrains Mono', 'Courier New', monospace;
  font-size: 0.85rem;
  line-height: 1.5;
  margin: 0;
  padding: 0.75rem;
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: 6px;
  white-space: pre-wrap;
  color: var(--text-primary);
}

.sample-explanation {
  padding-top: 0.75rem;
  border-top: 1px solid var(--border);
}

.sample-explanation p {
  margin: 0.5rem 0 0 0;
  font-size: 0.9rem;
  line-height: 1.6;
  color: var(--text-secondary);
}

.hint-content {
  background: var(--bg-tertiary);
  border-left: 3px solid var(--accent);
  padding: 1rem;
  border-radius: 6px;
}

.hint-content p {
  color: var(--text-primary);
  font-style: italic;
}

.code-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.75rem 1rem;
  background: var(--bg-tertiary);
  border-bottom: 1px solid var(--border);
}

.code-header-left {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.code-label {
  font-weight: 600;
  font-size: 0.9rem;
  color: var(--text-secondary);
}

.code-header-right {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.font-size-menu {
  position: relative;
}

.btn-icon {
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  color: var(--text-primary);
  padding: 0.5rem 0.75rem;
  border-radius: 6px;
  cursor: pointer;
  font-size: 1.2rem;
  transition: all 0.2s;
}

.btn-icon:hover {
  background: var(--bg-tertiary);
}

.font-size-dropdown {
  position: absolute;
  top: calc(100% + 0.5rem);
  right: 0;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: 8px;
  box-shadow: 0 4px 12px var(--shadow);
  z-index: 100;
  min-width: 100px;
  overflow: hidden;
}

.font-size-option {
  padding: 0.75rem 1rem;
  cursor: pointer;
  transition: background 0.2s;
  font-size: 0.9rem;
}

.font-size-option:hover {
  background: var(--bg-tertiary);
}

.font-size-option.active {
  background: var(--accent);
  color: white;
  font-weight: 600;
}

.btn {
  padding: 0.5rem 1.25rem;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  font-weight: 600;
  font-size: 0.9rem;
  transition: all 0.2s;
}

.btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.btn-success {
  background: var(--success);
  color: white;
}

.btn-success:hover:not(:disabled) {
  background: var(--success-hover);
  transform: translateY(-1px);
}

.btn-run {
  background: var(--accent);
  color: white;
}

.btn-run:hover:not(:disabled) {
  background: var(--accent-hover);
  transform: translateY(-1px);
}

.btn-primary {
  background: var(--accent);
  color: white;
  margin-top: 1rem;
}

.btn-primary:hover {
  background: var(--accent-hover);
}

.code-editor {
  flex: 1;
  overflow: hidden;
}

.code-textarea {
  width: 100%;
  height: 100%;
  padding: 1rem;
  background: var(--bg-primary);
  color: var(--text-primary);
  border: none;
  outline: none;
  font-family: 'JetBrains Mono', 'Courier New', monospace;
  line-height: 1.6;
  resize: none;
  tab-size: 4;
}

.code-textarea:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}

/* Output Section */
.resize-handle {
  height: 8px;
  background: var(--bg-tertiary);
  cursor: ns-resize;
  display: flex;
  align-items: center;
  justify-content: center;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  transition: background 0.2s;
  flex-shrink: 0;
}

.resize-handle:hover {
  background: var(--accent);
}

.resize-handle-line {
  width: 40px;
  height: 3px;
  background: var(--text-tertiary);
  border-radius: 2px;
}

.resize-handle:hover .resize-handle-line {
  background: white;
}

.output-section {
  display: flex;
  flex-direction: column;
  background: var(--bg-secondary);
  flex-shrink: 0;
}

.output-header {
  padding: 0.75rem 1rem;
  background: var(--bg-tertiary);
  border-bottom: 1px solid var(--border);
}

.output-tabs {
  display: flex;
  gap: 0.5rem;
}

.output-tab {
  padding: 0.5rem 1rem;
  background: transparent;
  border: none;
  color: var(--text-secondary);
  cursor: pointer;
  font-weight: 600;
  font-size: 0.9rem;
  border-bottom: 2px solid transparent;
  transition: all 0.2s;
}

.output-tab:hover {
  color: var(--text-primary);
}

.output-tab.active {
  color: var(--accent);
  border-bottom-color: var(--accent);
}

.output-content {
  flex: 1;
  overflow-y: auto;
  padding: 1rem;
}

.output-display {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  height: 100%;
}

.output-text {
  font-family: 'JetBrains Mono', 'Courier New', monospace;
  font-size: 0.9rem;
  line-height: 1.6;
  margin: 0;
  white-space: pre-wrap;
  word-wrap: break-word;
  flex: 1;
}

.output-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1rem;
  background: var(--bg-tertiary);
  border-radius: 8px;
  border: 1px solid var(--border);
}

.score-badge {
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--success);
}

.output-placeholder {
  color: var(--text-tertiary);
  font-style: italic;
}

.feedback-content {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.score-display h3 {
  margin: 0;
  font-size: 1.5rem;
  color: var(--success);
}

.feedback-text h4 {
  margin: 0 0 0.5rem 0;
  font-size: 1rem;
  color: var(--text-secondary);
}

.feedback-text p {
  margin: 0;
  line-height: 1.6;
}

/* Loading */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  font-size: 1.2rem;
  color: var(--text-secondary);
}

/* Scrollbar Styling */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: var(--bg-secondary);
}

::-webkit-scrollbar-thumb {
  background: var(--bg-tertiary);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--accent);
}

/* Responsive */
@media (max-width: 1024px) {
  .chatbot-drawer-toggle span:last-child {
    display: none;
  }
}

@media (max-width: 768px) {
  .coding-main-content {
    display: flex !important;
    flex-direction: column;
  }

  .left-panel {
    max-height: 300px;
    border-right: none;
    border-bottom: 1px solid var(--border);
  }

  .vertical-resize-handle {
    display: none;
  }

  .chatbot-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 90%;
    max-width: 400px;
    z-index: 1000;
    box-shadow: -4px 0 12px var(--shadow);
  }

  .output-section {
    height: 150px !important;
  }

  .sample-io {
    grid-template-columns: 1fr;
  }
}
